@page "/minecraft"
@rendermode InteractiveServer
@using BlazorThree
@using BlazorThree.Engine

<PageTitle>Minecraft Page</PageTitle>

<div class="minecraft-page">
    <div class="viewport-shell">
        <Scene Width="100%" Height="100%" ClearColor="#0b1118">
            <SceneTicker Tick="HandleTick" />
            <SceneInput Enabled="true"
                        CaptureKeyboard="true"
                        CaptureMouse="true"
                        RequestPointerLockOnClick="true"
                        KeyDown="HandleKeyDown"
                        KeyUp="HandleKeyUp"
                        MouseMove="HandleMouseMove"
                        MouseDown="HandleMouseDown"
                        PointerLockChanged="HandlePointerLockChanged" />

            <Camera Fov="70"
                    PositionX="@cameraX"
                    PositionY="@cameraY"
                    PositionZ="@cameraZ"
                    RotationX="@pitch"
                    RotationY="@yaw"
                    RotationZ="0" />

            <Light Type="LightDefinitions.Ambient" Intensity="0.75" />
            <Light Type="LightDefinitions.Directional" Intensity="1.35" PositionX="6" PositionY="12" PositionZ="8" />

            @foreach (var block in blocks)
            {
                <Mesh @key="block.Key.X * 73856093 + block.Key.Y * 19349663 + block.Key.Z * 83492791"
                      PositionX="@block.Key.X"
                      PositionY="@block.Key.Y"
                      PositionZ="@block.Key.Z">
                    <BoxGeometry Width="1" Height="1" Depth="1" />
                    <MeshStandardMaterial Color="@GetBlockColor(block.Value)" Metalness="0.0" Roughness="1.0" />
                </Mesh>
            }

            @if (targetBlock.HasValue)
            {
                <Mesh PositionX="@targetBlock.Value.X"
                      PositionY="@targetBlock.Value.Y"
                      PositionZ="@targetBlock.Value.Z"
                      ScaleX="1.03"
                      ScaleY="1.03"
                      ScaleZ="1.03">
                    <BoxGeometry Width="1" Height="1" Depth="1" />
                    <MeshStandardMaterial Color="#ffdd57" Metalness="0" Roughness="0.5" />
                    <Outline Color="#ffdd57" Opacity="0.95" />
                </Mesh>
            }
        </Scene>

        <div class="crosshair" aria-hidden="true"></div>
    </div>

    <aside class="panel">
        <h1>Minecraft Page</h1>
        <p class="description">WASD moves, mouse looks, Space jumps. Left click breaks a block and right click places one. Press 1-4 to swap the block type.</p>

        <div class="controls">
            <button class="btn btn-warning" @onclick="ResetWorld">Reset World</button>
        </div>

        <div class="controls">
            <button class="btn btn-outline-light" @onclick="() => SelectBlockType(BlockType.Grass)">Grass</button>
            <button class="btn btn-outline-light" @onclick="() => SelectBlockType(BlockType.Dirt)">Dirt</button>
            <button class="btn btn-outline-light" @onclick="() => SelectBlockType(BlockType.Stone)">Stone</button>
            <button class="btn btn-outline-light" @onclick="() => SelectBlockType(BlockType.Wood)">Wood</button>
        </div>

        <div class="tips">
            <div>Pointer lock is requested on scene click.</div>
            <div>Mouse movement controls yaw and pitch.</div>
            <div>Block selection uses a voxel ray cast from the camera.</div>
            <div>Current block: @selectedBlockType</div>
        </div>
    </aside>
</div>

<style>
    .minecraft-page {
        position: relative;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        background:
            radial-gradient(circle at top, rgba(111, 173, 255, 0.18), transparent 42%),
            linear-gradient(180deg, #111722 0%, #0a0f16 100%);
    }

    .viewport-shell {
        position: absolute;
        inset: 0;
    }

    .crosshair {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 18px;
        height: 18px;
        margin-left: -9px;
        margin-top: -9px;
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-left: none;
        border-right: none;
        opacity: 0.9;
        pointer-events: none;
    }

    .crosshair::before {
        content: "";
        position: absolute;
        left: 50%;
        top: 0;
        width: 1px;
        height: 18px;
        margin-left: -0.5px;
        background: rgba(255, 255, 255, 0.6);
    }

    .panel {
        position: absolute;
        top: 1rem;
        left: 1rem;
        width: min(420px, calc(100vw - 2rem));
        padding: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        background: rgba(10, 14, 22, 0.78);
        backdrop-filter: blur(14px);
        color: #ffffff;
        z-index: 5;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }

    .panel h1 {
        margin: 0;
        font-size: 1.15rem;
        letter-spacing: 0.04em;
    }

    .description,
    .tips {
        margin: 0;
        color: #b8c4d9;
        font-size: 0.92rem;
        line-height: 1.45;
    }

    .controls {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tips {
        display: grid;
        gap: 0.35rem;
        padding-top: 0.35rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    @@media (max-width: 760px) {
        .panel {
            top: auto;
            bottom: 1rem;
            left: 1rem;
            right: 1rem;
            width: auto;
        }
    }
</style>

@code {
    private const double PlayerHeight = 1.8;
    private const double EyeHeight = 1.6;
    private const double PlayerRadius = 0.3;
    private const double MoveSpeed = 5.5;
    private const double Gravity = 18.0;
    private const double JumpVelocity = 7.5;
    private const double MouseSensitivity = 0.0025;
    private const double MaxPitch = 1.45;
    private const double MaxTargetDistance = 8.0;
    private const double RenderIntervalMs = 50;

    private readonly Dictionary<GridPoint, BlockType> blocks = new();

    private BlockType selectedBlockType = BlockType.Grass;

    private PlayerState player = new();

    private GridPoint? targetBlock;

    private GridPoint? placementBlock;

    private bool moveForward;

    private bool moveBackward;

    private bool moveLeft;

    private bool moveRight;

    private bool jumpRequested;

    private bool pointerLocked;

    private double lastRenderTimestampMs;

    private double yaw = Math.PI;

    private double pitch;

    private double cameraX => player.X;

    private double cameraY => player.Y + EyeHeight;

    private double cameraZ => player.Z;

    protected override void OnInitialized()
    {
        ResetWorld();
    }

    private void ResetWorld()
    {
        blocks.Clear();
        BuildTerrain();
        ResetPlayer();
        targetBlock = null;
        placementBlock = null;
        _ = InvokeAsync(StateHasChanged);
    }

    private void BuildTerrain()
    {
        for (var x = -7; x <= 7; x++)
        {
            for (var z = -7; z <= 7; z++)
            {
                AddBlock(new GridPoint(x, 0, z), BlockType.Grass);
                AddBlock(new GridPoint(x, -1, z), BlockType.Dirt);

                var variation = Math.Abs(Math.Sin(x * 12.9898 + z * 78.233));
                if (variation > 0.87)
                {
                    AddBlock(new GridPoint(x, 1, z), BlockType.Grass);
                }

                if (variation > 0.94)
                {
                    AddBlock(new GridPoint(x, 2, z), BlockType.Stone);
                }
            }
        }

        for (var x = -3; x <= 3; x++)
        {
            for (var y = 1; y <= 4; y++)
            {
                AddBlock(new GridPoint(x, y, 4), y == 4 ? BlockType.Grass : BlockType.Wood);
            }
        }
    }

    private void AddBlock(GridPoint position, BlockType type)
    {
        blocks[position] = type;
    }

    private void RemoveBlock(GridPoint position)
    {
        blocks.Remove(position);
    }

    private void ResetPlayer()
    {
        player = new PlayerState
        {
            X = 0,
            Y = 3.5,
            Z = 8,
            VelocityX = 0,
            VelocityY = 0,
            VelocityZ = 0,
            OnGround = false
        };

        yaw = Math.PI;
        pitch = 0;
        moveForward = false;
        moveBackward = false;
        moveLeft = false;
        moveRight = false;
        jumpRequested = false;
    }

    private void SelectBlockType(BlockType blockType)
    {
        selectedBlockType = blockType;
    }

    private Task HandleTick(SceneFrameInfo frameInfo)
    {
        UpdatePlayer(frameInfo.DeltaSeconds);

        if (frameInfo.TimestampMs - lastRenderTimestampMs >= RenderIntervalMs)
        {
            lastRenderTimestampMs = frameInfo.TimestampMs;
            UpdateTarget();
            _ = InvokeAsync(StateHasChanged);
        }

        return Task.CompletedTask;
    }

    private Task HandleKeyDown(SceneKeyboardEventInfo eventInfo)
    {
        switch (eventInfo.Code)
        {
            case "KeyW":
                moveForward = true;
                break;
            case "KeyS":
                moveBackward = true;
                break;
            case "KeyA":
                moveLeft = true;
                break;
            case "KeyD":
                moveRight = true;
                break;
            case "Space":
                jumpRequested = true;
                break;
            case "Digit1":
                selectedBlockType = BlockType.Grass;
                break;
            case "Digit2":
                selectedBlockType = BlockType.Dirt;
                break;
            case "Digit3":
                selectedBlockType = BlockType.Stone;
                break;
            case "Digit4":
                selectedBlockType = BlockType.Wood;
                break;
            case "KeyR":
                ResetWorld();
                break;
        }

        _ = InvokeAsync(StateHasChanged);

        return Task.CompletedTask;
    }

    private Task HandleKeyUp(SceneKeyboardEventInfo eventInfo)
    {
        switch (eventInfo.Code)
        {
            case "KeyW":
                moveForward = false;
                break;
            case "KeyS":
                moveBackward = false;
                break;
            case "KeyA":
                moveLeft = false;
                break;
            case "KeyD":
                moveRight = false;
                break;
            case "Space":
                jumpRequested = false;
                break;
        }

        return Task.CompletedTask;
    }

    private Task HandleMouseMove(SceneMouseEventInfo eventInfo)
    {
        if (!pointerLocked)
        {
            return Task.CompletedTask;
        }

        yaw -= eventInfo.MovementX * MouseSensitivity;
        pitch = Clamp(pitch - eventInfo.MovementY * MouseSensitivity, -MaxPitch, MaxPitch);
        return Task.CompletedTask;
    }

    private Task HandleMouseDown(SceneMouseEventInfo eventInfo)
    {
        if (!pointerLocked)
        {
            return Task.CompletedTask;
        }

        if (eventInfo.Button == 0)
        {
            if (targetBlock.HasValue)
            {
                RemoveBlock(targetBlock.Value);
                targetBlock = null;
                placementBlock = null;
                _ = InvokeAsync(StateHasChanged);
            }
        }
        else if (eventInfo.Button == 2 && placementBlock.HasValue && !blocks.ContainsKey(placementBlock.Value))
        {
            AddBlock(placementBlock.Value, selectedBlockType);
            _ = InvokeAsync(StateHasChanged);
        }

        return Task.CompletedTask;
    }

    private Task HandlePointerLockChanged(ScenePointerLockInfo eventInfo)
    {
        pointerLocked = eventInfo.IsLocked;
        if (!pointerLocked)
        {
            moveForward = false;
            moveBackward = false;
            moveLeft = false;
            moveRight = false;
            jumpRequested = false;
        }

        _ = InvokeAsync(StateHasChanged);

        return Task.CompletedTask;
    }

    private void UpdatePlayer(double deltaSeconds)
    {
        var forwardX = Math.Sin(yaw);
        var forwardZ = Math.Cos(yaw);
        var rightX = forwardZ;
        var rightZ = -forwardX;

        var moveX = 0.0;
        var moveZ = 0.0;

        if (moveForward)
        {
            moveX += forwardX;
            moveZ += forwardZ;
        }

        if (moveBackward)
        {
            moveX -= forwardX;
            moveZ -= forwardZ;
        }

        if (moveRight)
        {
            moveX += rightX;
            moveZ += rightZ;
        }

        if (moveLeft)
        {
            moveX -= rightX;
            moveZ -= rightZ;
        }

        var moveLength = Math.Sqrt(moveX * moveX + moveZ * moveZ);
        if (moveLength > 0)
        {
            moveX = moveX / moveLength * MoveSpeed;
            moveZ = moveZ / moveLength * MoveSpeed;
        }

        player.VelocityX = moveX;
        player.VelocityZ = moveZ;

        if (jumpRequested && player.OnGround)
        {
            player.VelocityY = JumpVelocity;
            player.OnGround = false;
            jumpRequested = false;
        }

        player.VelocityY -= Gravity * deltaSeconds;

        ResolveAxis('x', player.VelocityX * deltaSeconds);
        ResolveAxis('z', player.VelocityZ * deltaSeconds);
        ResolveAxis('y', player.VelocityY * deltaSeconds);

        if (player.Y < -20)
        {
            ResetPlayer();
        }
    }

    private void ResolveAxis(char axis, double delta)
    {
        if (Math.Abs(delta) < 0.000001)
        {
            return;
        }

        if (axis == 'x')
        {
            player.X += delta;
        }
        else if (axis == 'y')
        {
            player.Y += delta;
        }
        else if (axis == 'z')
        {
            player.Z += delta;
        }

        var bounds = GetPlayerBounds();

        foreach (var block in GetNearbyBlocks(bounds))
        {
            var blockBounds = GetBlockBounds(block.Key);
            if (!Intersects(bounds, blockBounds))
            {
                continue;
            }

            if (axis == 'x')
            {
                player.X = delta > 0
                    ? block.Key.X - 0.5 - PlayerRadius
                    : block.Key.X + 0.5 + PlayerRadius;
                player.VelocityX = 0;
            }
            else if (axis == 'z')
            {
                player.Z = delta > 0
                    ? block.Key.Z - 0.5 - PlayerRadius
                    : block.Key.Z + 0.5 + PlayerRadius;
                player.VelocityZ = 0;
            }
            else if (axis == 'y')
            {
                if (delta > 0)
                {
                    player.Y = block.Key.Y - 0.5 - PlayerHeight;
                    player.VelocityY = 0;
                }
                else
                {
                    player.Y = block.Key.Y + 0.5;
                    player.VelocityY = 0;
                    player.OnGround = true;
                }
            }

            bounds = GetPlayerBounds();
        }
    }

    private IEnumerable<KeyValuePair<GridPoint, BlockType>> GetNearbyBlocks(PlayerBounds bounds)
    {
        var minX = (int)Math.Floor(bounds.MinX - 0.5);
        var maxX = (int)Math.Floor(bounds.MaxX + 0.5);
        var minY = (int)Math.Floor(bounds.MinY - 0.5);
        var maxY = (int)Math.Floor(bounds.MaxY + 0.5);
        var minZ = (int)Math.Floor(bounds.MinZ - 0.5);
        var maxZ = (int)Math.Floor(bounds.MaxZ + 0.5);

        for (var x = minX; x <= maxX; x++)
        {
            for (var y = minY; y <= maxY; y++)
            {
                for (var z = minZ; z <= maxZ; z++)
                {
                    var key = new GridPoint(x, y, z);
                    if (blocks.TryGetValue(key, out var type))
                    {
                        yield return new KeyValuePair<GridPoint, BlockType>(key, type);
                    }
                }
            }
        }
    }

    private PlayerBounds GetPlayerBounds()
    {
        return new PlayerBounds
        {
            MinX = player.X - PlayerRadius,
            MaxX = player.X + PlayerRadius,
            MinY = player.Y,
            MaxY = player.Y + PlayerHeight,
            MinZ = player.Z - PlayerRadius,
            MaxZ = player.Z + PlayerRadius
        };
    }

    private static PlayerBounds GetBlockBounds(GridPoint position)
    {
        return new PlayerBounds
        {
            MinX = position.X - 0.5,
            MaxX = position.X + 0.5,
            MinY = position.Y - 0.5,
            MaxY = position.Y + 0.5,
            MinZ = position.Z - 0.5,
            MaxZ = position.Z + 0.5
        };
    }

    private static bool Intersects(PlayerBounds a, PlayerBounds b)
    {
        return a.MinX <= b.MaxX && a.MaxX >= b.MinX
            && a.MinY <= b.MaxY && a.MaxY >= b.MinY
            && a.MinZ <= b.MaxZ && a.MaxZ >= b.MinZ;
    }

    private void UpdateTarget()
    {
        if (!pointerLocked)
        {
            targetBlock = null;
            placementBlock = null;
            return;
        }

        if (TryRayCast(out var hitBlock, out var placeBlock))
        {
            targetBlock = hitBlock;
            placementBlock = placeBlock;
        }
        else
        {
            targetBlock = null;
            placementBlock = null;
        }
    }

    private bool TryRayCast(out GridPoint hitBlock, out GridPoint placeBlock)
    {
        var originX = player.X;
        var originY = player.Y + EyeHeight;
        var originZ = player.Z;

        var directionX = Math.Cos(pitch) * Math.Sin(yaw);
        var directionY = Math.Sin(pitch);
        var directionZ = Math.Cos(pitch) * Math.Cos(yaw);

        if (Math.Abs(directionX) < 0.000001 && Math.Abs(directionY) < 0.000001 && Math.Abs(directionZ) < 0.000001)
        {
            hitBlock = default;
            placeBlock = default;
            return false;
        }

        var currentX = (int)Math.Floor(originX);
        var currentY = (int)Math.Floor(originY);
        var currentZ = (int)Math.Floor(originZ);

        var stepX = directionX > 0 ? 1 : -1;
        var stepY = directionY > 0 ? 1 : -1;
        var stepZ = directionZ > 0 ? 1 : -1;

        var tMaxX = IntBound(originX, directionX);
        var tMaxY = IntBound(originY, directionY);
        var tMaxZ = IntBound(originZ, directionZ);

        var tDeltaX = directionX == 0 ? double.PositiveInfinity : Math.Abs(1 / directionX);
        var tDeltaY = directionY == 0 ? double.PositiveInfinity : Math.Abs(1 / directionY);
        var tDeltaZ = directionZ == 0 ? double.PositiveInfinity : Math.Abs(1 / directionZ);

        var travelled = 0.0;
        var lastFaceX = 0;
        var lastFaceY = 0;
        var lastFaceZ = 0;

        while (travelled <= MaxTargetDistance)
        {
            var current = new GridPoint(currentX, currentY, currentZ);
            if (blocks.ContainsKey(current))
            {
                hitBlock = current;
                placeBlock = new GridPoint(currentX + lastFaceX, currentY + lastFaceY, currentZ + lastFaceZ);
                return true;
            }

            if (tMaxX < tMaxY)
            {
                if (tMaxX < tMaxZ)
                {
                    currentX += stepX;
                    travelled = tMaxX;
                    tMaxX += tDeltaX;
                    lastFaceX = -stepX;
                    lastFaceY = 0;
                    lastFaceZ = 0;
                }
                else
                {
                    currentZ += stepZ;
                    travelled = tMaxZ;
                    tMaxZ += tDeltaZ;
                    lastFaceX = 0;
                    lastFaceY = 0;
                    lastFaceZ = -stepZ;
                }
            }
            else
            {
                if (tMaxY < tMaxZ)
                {
                    currentY += stepY;
                    travelled = tMaxY;
                    tMaxY += tDeltaY;
                    lastFaceX = 0;
                    lastFaceY = -stepY;
                    lastFaceZ = 0;
                }
                else
                {
                    currentZ += stepZ;
                    travelled = tMaxZ;
                    tMaxZ += tDeltaZ;
                    lastFaceX = 0;
                    lastFaceY = 0;
                    lastFaceZ = -stepZ;
                }
            }
        }

        hitBlock = default;
        placeBlock = default;
        return false;
    }

    private static double IntBound(double s, double ds)
    {
        if (ds == 0)
        {
            return double.PositiveInfinity;
        }

        var sIsInteger = Math.Abs(s - Math.Round(s)) < 0.000001;
        if (ds > 0)
        {
            return (sIsInteger ? 1.0 : Math.Ceiling(s) - s) / ds;
        }

        return (sIsInteger ? 0.0 : s - Math.Floor(s)) / -ds;
    }

    private string GetBlockColor(BlockType type)
    {
        return type switch
        {
            BlockType.Grass => "#73bf44",
            BlockType.Dirt => "#8c6239",
            BlockType.Stone => "#8e949f",
            BlockType.Wood => "#b57b47",
            _ => "#ffffff"
        };
    }

    private static double Clamp(double value, double min, double max)
    {
        return Math.Min(max, Math.Max(min, value));
    }

    private record PlayerState
    {
        public double X { get; set; }

        public double Y { get; set; }

        public double Z { get; set; }

        public double VelocityX { get; set; }

        public double VelocityY { get; set; }

        public double VelocityZ { get; set; }

        public bool OnGround { get; set; }
    }

    private record struct PlayerBounds
    {
        public double MinX { get; set; }

        public double MaxX { get; set; }

        public double MinY { get; set; }

        public double MaxY { get; set; }

        public double MinZ { get; set; }

        public double MaxZ { get; set; }
    }

    private readonly record struct GridPoint(int X, int Y, int Z);

    private enum BlockType
    {
        Grass,
        Dirt,
        Stone,
        Wood
    }
}
