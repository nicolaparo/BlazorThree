@page "/"
@using BlazorThree.Engine
@rendermode InteractiveServer

<PageTitle>BlazorThree Demo</PageTitle>

<div class="scene-page">
    <Scene Width="100%" Height="100%" ClearColor="#101925">
        <Camera Fov="65" Position="@(new(0f, 1.4f, 7f))" />
        <Light Type="LightDefinitions.Directional" Intensity="1.6" Position="@(new(6f, 8f, 3f))" />
        <OrbitControls Enabled="true" EnableDamping="true" DampingFactor="0.09" />

        <Group Position="@(stageActive ? new(0f, 0.9f, 0f) : Vector3.Zero)"
               Rotation="@(stageActive ? new(0f, 1.8f, 0f) : Vector3.Zero)"
               Scale="@(stageActive ? new(-1f, -1f, -1f) : Vector3.One)">

            <Transition Properties="@([nameof(Group.Position), nameof(Group.Rotation), nameof(Group.Scale)])" 
                        DurationMs="1200" 
                        Easing="@Easings.EaseInOutQuad"/>

            @if (boxVisible)
            {
                <Mesh Position="@(new(-1.7f, 0.1f, 0f))"
                      OnClick='() => selectedElement = "box"'>
                    <BoxGeometry Width="1" Height="1" Depth="1"/>
                    <MeshStandardMaterial Color="#f5f500" Metalness="0.05" Roughness="0.55" />
                    @if (selectedElement == "box")
                    {
                        <Outline Color="#ff0000" Opacity="0.98"/>
                    }
                </Mesh>
            }
            
            @if (sphereVisible)
            {
                <Mesh id="sphere"
                      Position="@(new Vector3(1.7f, 0.1f, 0f))"
                      Scale="sphereScale"
                      OnMouseEnter="() => sphereScale = Vector3.One * 1.5f"
                      OnMouseLeave="() => sphereScale = Vector3.One"
                      OnClick='() => selectedElement = "sphere"'>
                    
                    <Transition Property="@nameof(Mesh.Scale)" DurationMs="500" Easing="@Easings.EaseInOutQuad"></Transition>
                    <SphereGeometry Radius="0.9" WidthSegments="48" HeightSegments="24"/>
                    <MeshStandardMaterial Color="#ffffff"
                                          TextureUrl="https://threejs.org/examples/textures/uv_grid_opengl.jpg"
                                          Metalness="0.05"
                                          Roughness="0.55"/>
                    @if (selectedElement == "sphere")
                    {
                        <Outline Color="#0000ff" Opacity="0.98"/>
                    }
                </Mesh>
            }
        </Group>

        <Mesh Position="@(new Vector3(0f, -1.5f, 0f))">
            <BoxGeometry Width="6" Height="0.18" Depth="3" />
            <MeshStandardMaterial Color="#6ca0ff" Metalness="0.15" Roughness="0.9" />
        </Mesh>
    </Scene>

    <aside class="right-panel">
        <h2>Controls</h2>
        <button class="btn btn-primary" @onclick="() => stageActive = !stageActive">
            Toggle Stage (@(stageActive ? "active" : "idle"))
        </button>
        <div class="row">
            <div class="col">
                <input id="box-visible" type="checkbox" @bind="boxVisible" />
                <label for="box-visible">Box Visible</label>
            </div>
            <div class="col">
                <input id="sphere-visible" type="checkbox" @bind="sphereVisible" />
                <label for="sphere-visible">Sphere Visible</label>
            </div>
        </div>
    </aside>
</div>

<style>
    .scene-page {
        position: relative;
        width: 100vw;
        height: 100vh;
    }

    .right-panel {
        position: absolute;
        top: 0;
        right: 0;
        height: 100%;
        width: min(320px, 32vw);
        padding: 1rem;
        background: rgba(12, 16, 24, 0.76);
        backdrop-filter: blur(8px);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        color: #ffffff;
        z-index: 5;
    }

        .right-panel h2 {
            margin: 0;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

    @@media (max-width: 720px) {
        .right-panel {
            width: 220px;
        }
    }
</style>

@code {
    private bool stageActive;
    private bool boxVisible = true;
    private bool sphereVisible = true;
    private string selectedElement = "";
    private Vector3 sphereScale = Vector3.One;
}
