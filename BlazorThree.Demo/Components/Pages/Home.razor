@page "/"
@using BlazorThree.Engine
@rendermode InteractiveServer

<PageTitle>BlazorThree Demo</PageTitle>

<div class="scene-page">
    <Scene Width="100%"
           Height="100%"
           ClearColor="#101925">
        <Camera Fov="65" Position="@(new Vector3(0f, 1.4f, 7f))" />
        <Light Type="LightDefinitions.Directional" Intensity="1.6" Position="@(new Vector3(6f, 8f, 3f))" />
        <OrbitControls Enabled="true" EnableDamping="true" DampingFactor="0.09" />

        <Transition ClassName="stage-idle" DurationMs="550" Easing="easeInOutQuad" Position="@Vector3.Zero" Rotation="@Vector3.Zero" Scale="@Vector3.One" />
        <Transition ClassName="stage-active" DurationMs="1200" Easing="easeOutCubic" Position="@(new Vector3(0f, 0.9f, 0f))" Rotation="@(new Vector3(0f, 1.8f, 0f))" Scale="@(new Vector3(1.2f, 1.2f, 1.2f))" />

        <Group Position="@Vector3.Zero" ClassName="@currentStageClass">

            <Mesh id="cube"
                Position="@(new Vector3(-1.7f, 0.1f, 0f))"
                Click="OnElementClick"
                MouseEnter="OnElementMouseEnter"
                MouseLeave="OnElementMouseLeave">
                <BoxGeometry Width="1" Height="1" Depth="1"/>
                <MeshStandardMaterial Color="#f5f500" Metalness="0.05" Roughness="0.55"/>
                @if (TryGetOutlineColor("cube") is string cubeOutlineColor)
                {
                    <Outline Color="@cubeOutlineColor" Opacity="0.98"/>
                }
            </Mesh>

            <Mesh id="sphere"
                Position="@(new Vector3(1.7f, 0.1f, 0f))"
                Click="OnElementClick"
                MouseEnter="OnElementMouseEnter"
                MouseLeave="OnElementMouseLeave">
                <SphereGeometry Radius="0.9" WidthSegments="48" HeightSegments="24"/>
                <MeshStandardMaterial Color="#ffffff"
                                      TextureUrl="https://threejs.org/examples/textures/uv_grid_opengl.jpg"
                                      Metalness="0.05"
                                      Roughness="0.55"/>
                @if (TryGetOutlineColor("sphere") is string sphereOutlineColor)
                {
                    <Outline Color="@sphereOutlineColor" Opacity="0.98"/>
                }
            </Mesh>
        </Group>

        <Mesh Position="@(new Vector3(0f, -1.5f, 0f))">
            <BoxGeometry Width="6" Height="0.18" Depth="3" />
            <MeshStandardMaterial Color="#6ca0ff" Metalness="0.15" Roughness="0.9" />
        </Mesh>
    </Scene>

    <aside class="right-panel">
        <h2>Controls</h2>
        <button class="btn btn-primary" @onclick="ToggleStageClass">
            Toggle Class (@currentStageClass)
        </button>
        <button class="btn btn-outline-light" @onclick="ToggleTimeline">
            Timeline (@(timelineEnabled ? "On" : "Off"))
        </button>
        <button class="btn btn-outline-light" @onclick="ToggleBulbasaurPose">
            Bulbasaur Pose (@(bulbasaurPoseApplied ? "On" : "Off"))
        </button>
        <button class="btn btn-outline-light" @onclick="ToggleBulbasaurAnimation">
            Bulbasaur Clip Playback (@(bulbasaurAnimationPlaying ? "On" : "Off"))
        </button>
    </aside>
</div>

<style>
    .scene-page {
        position: relative;
        width: 100vw;
        height: 100vh;
    }

    .right-panel {
        position: absolute;
        top: 0;
        right: 0;
        height: 100%;
        width: min(320px, 32vw);
        padding: 1rem;
        background: rgba(12, 16, 24, 0.76);
        backdrop-filter: blur(8px);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        color: #ffffff;
        z-index: 5;
    }

        .right-panel h2 {
            margin: 0;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

    @@media (max-width: 720px) {
        .right-panel {
            width: 220px;
        }
    }
</style>

@code {
    private static readonly IReadOnlyList<BonePoseState> BulbasaurLookLeftPose =
    [
        new BonePoseState
        {
            BoneName = "Bone1",
            Rotation = new Vector3(0f, 0.35f, 0.05f)
        },
        new BonePoseState
        {
            BoneName = "Bone2",
            Rotation = new Vector3(0f, 0.2f, 0f)
        }
    ];

    private string currentStageClass = "stage-idle";

    private bool timelineEnabled = true;

    private bool bulbasaurPoseApplied = true;

    private bool bulbasaurAnimationPlaying = true;

    private IReadOnlyList<BonePoseState> bulbasaurBonePoses = BulbasaurLookLeftPose;

    private string? hoveredElementId;

    private string? selectedElementId;

    private void ToggleStageClass()
    {
        currentStageClass = currentStageClass == "stage-idle" ? "stage-active" : "stage-idle";
    }

    private void ToggleTimeline()
    {
        timelineEnabled = !timelineEnabled;
    }

    private void ToggleBulbasaurPose()
    {
        bulbasaurPoseApplied = !bulbasaurPoseApplied;
        bulbasaurBonePoses = bulbasaurPoseApplied ? BulbasaurLookLeftPose : Array.Empty<BonePoseState>();
    }

    private void ToggleBulbasaurAnimation()
    {
        bulbasaurAnimationPlaying = !bulbasaurAnimationPlaying;
    }

    private void OnElementMouseEnter(SceneElementMouseEventArgs args)
    {
        hoveredElementId = args.ElementId;
    }

    private void OnElementMouseLeave(SceneElementMouseEventArgs args)
    {
        hoveredElementId = null;
    }

    private void OnElementClick(SceneElementMouseEventArgs args)
    {
        selectedElementId = args.ElementId;
    }

    private string? TryGetOutlineColor(string elementId)
    {
        if (string.Equals(selectedElementId, elementId, StringComparison.Ordinal))
        {
            return "#2f80ff";
        }

        if (string.Equals(hoveredElementId, elementId, StringComparison.Ordinal))
        {
            return "#ffd84d";
        }

        return null;
    }
}
