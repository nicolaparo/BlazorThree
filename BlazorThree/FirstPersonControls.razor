@code {
    [CascadingParameter]
    public SceneContext? SceneContext { get; set; }

    [Parameter]
    public bool Enabled { get; set; } = true;

    [Parameter]
    public double MoveSpeed { get; set; } = 4.5;

    [Parameter]
    public double LookSensitivity { get; set; } = 0.0025;

    [Parameter]
    public double EyeHeight { get; set; } = 1.6;

    [Parameter]
    public bool LockPointerOnClick { get; set; } = true;

    protected override void OnParametersSet()
    {
        SceneContext?.SetFirstPersonControls(new FirstPersonControlsState
        {
            Enabled = Enabled,
            MoveSpeed = MoveSpeed,
            LookSensitivity = LookSensitivity,
            EyeHeight = EyeHeight,
            LockPointerOnClick = LockPointerOnClick
        });
    }
}