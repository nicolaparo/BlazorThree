@implements IDisposable

@code {
    private SceneContext? subscribedContext;

    [CascadingParameter]
    public SceneContext? SceneContext { get; set; }

    [Parameter]
    public Func<SceneKeyboardEventInfo, Task>? KeyDown { get; set; }

    [Parameter]
    public Func<SceneKeyboardEventInfo, Task>? KeyUp { get; set; }

    [Parameter]
    public Func<SceneMouseEventInfo, Task>? MouseMove { get; set; }

    [Parameter]
    public Func<SceneMouseEventInfo, Task>? MouseDown { get; set; }

    [Parameter]
    public Func<SceneMouseEventInfo, Task>? MouseUp { get; set; }

    [Parameter]
    public Func<ScenePointerLockInfo, Task>? PointerLockChanged { get; set; }

    [Parameter]
    public bool Enabled { get; set; } = true;

    [Parameter]
    public bool CaptureKeyboard { get; set; } = true;

    [Parameter]
    public bool CaptureMouse { get; set; } = true;

    [Parameter]
    public bool RequestPointerLockOnClick { get; set; } = true;

    [Parameter]
    public EventCallback<SceneKeyboardEventInfo> OnKeyDown { get; set; }

    [Parameter]
    public EventCallback<SceneKeyboardEventInfo> OnKeyUp { get; set; }

    [Parameter]
    public EventCallback<SceneMouseEventInfo> OnMouseMove { get; set; }

    [Parameter]
    public EventCallback<SceneMouseEventInfo> OnMouseDown { get; set; }

    [Parameter]
    public EventCallback<SceneMouseEventInfo> OnMouseUp { get; set; }

    [Parameter]
    public EventCallback<ScenePointerLockInfo> OnPointerLockChanged { get; set; }

    protected override void OnInitialized()
    {
        TryAttachContext();
    }

    protected override void OnParametersSet()
    {
        TryAttachContext();

        SceneContext?.SetInputOptions(new SceneInputOptionsState
        {
            Enabled = Enabled,
            CaptureKeyboard = CaptureKeyboard,
            CaptureMouse = CaptureMouse,
            RequestPointerLockOnClick = RequestPointerLockOnClick
        });
    }

    private void HandleKeyDown(SceneKeyboardEventInfo eventInfo)
    {
        if (KeyDown is not null)
        {
            _ = KeyDown(eventInfo);
            return;
        }

        if (OnKeyDown.HasDelegate)
        {
            _ = InvokeAsync(() => OnKeyDown.InvokeAsync(eventInfo));
        }
    }

    private void HandleKeyUp(SceneKeyboardEventInfo eventInfo)
    {
        if (KeyUp is not null)
        {
            _ = KeyUp(eventInfo);
            return;
        }

        if (OnKeyUp.HasDelegate)
        {
            _ = InvokeAsync(() => OnKeyUp.InvokeAsync(eventInfo));
        }
    }

    private void HandleMouseMove(SceneMouseEventInfo eventInfo)
    {
        if (MouseMove is not null)
        {
            _ = MouseMove(eventInfo);
            return;
        }

        if (OnMouseMove.HasDelegate)
        {
            _ = InvokeAsync(() => OnMouseMove.InvokeAsync(eventInfo));
        }
    }

    private void HandleMouseDown(SceneMouseEventInfo eventInfo)
    {
        if (MouseDown is not null)
        {
            _ = MouseDown(eventInfo);
            return;
        }

        if (OnMouseDown.HasDelegate)
        {
            _ = InvokeAsync(() => OnMouseDown.InvokeAsync(eventInfo));
        }
    }

    private void HandleMouseUp(SceneMouseEventInfo eventInfo)
    {
        if (MouseUp is not null)
        {
            _ = MouseUp(eventInfo);
            return;
        }

        if (OnMouseUp.HasDelegate)
        {
            _ = InvokeAsync(() => OnMouseUp.InvokeAsync(eventInfo));
        }
    }

    private void HandlePointerLockChanged(ScenePointerLockInfo eventInfo)
    {
        if (PointerLockChanged is not null)
        {
            _ = PointerLockChanged(eventInfo);
            return;
        }

        if (OnPointerLockChanged.HasDelegate)
        {
            _ = InvokeAsync(() => OnPointerLockChanged.InvokeAsync(eventInfo));
        }
    }

    public void Dispose()
    {
        if (subscribedContext is not null)
        {
            subscribedContext.KeyDown -= HandleKeyDown;
            subscribedContext.KeyUp -= HandleKeyUp;
            subscribedContext.MouseMove -= HandleMouseMove;
            subscribedContext.MouseDown -= HandleMouseDown;
            subscribedContext.MouseUp -= HandleMouseUp;
            subscribedContext.PointerLockChanged -= HandlePointerLockChanged;
            subscribedContext = null;
        }
    }

    private void TryAttachContext()
    {
        if (ReferenceEquals(subscribedContext, SceneContext))
        {
            return;
        }

        if (subscribedContext is not null)
        {
            subscribedContext.KeyDown -= HandleKeyDown;
            subscribedContext.KeyUp -= HandleKeyUp;
            subscribedContext.MouseMove -= HandleMouseMove;
            subscribedContext.MouseDown -= HandleMouseDown;
            subscribedContext.MouseUp -= HandleMouseUp;
            subscribedContext.PointerLockChanged -= HandlePointerLockChanged;
        }

        subscribedContext = SceneContext;
        if (subscribedContext is not null)
        {
            subscribedContext.KeyDown += HandleKeyDown;
            subscribedContext.KeyUp += HandleKeyUp;
            subscribedContext.MouseMove += HandleMouseMove;
            subscribedContext.MouseDown += HandleMouseDown;
            subscribedContext.MouseUp += HandleMouseUp;
            subscribedContext.PointerLockChanged += HandlePointerLockChanged;
        }
    }
}