@implements IDisposable
@implements IPositionable
@implements IRotatable
@implements IScalable

@code {
    private readonly string id = Guid.NewGuid().ToString("N");

    [CascadingParameter]
    public TimelineTrackContext? TimelineTrackContext { get; set; }

    [Parameter]
    public double TimeMs { get; set; }

    [Parameter]
    public Vector3? Position { get; set; }

    [Parameter]
    public Vector3? Rotation { get; set; }

    [Parameter]
    public Vector3? Scale { get; set; }

    Vector3 IPositionable.Position
    {
        get => Position ?? Vector3.Zero;
        set => Position = value;
    }

    Vector3 IRotatable.Rotation
    {
        get => Rotation ?? Vector3.Zero;
        set => Rotation = value;
    }

    Vector3 IScalable.Scale
    {
        get => Scale ?? Vector3.Zero;
        set => Scale = value;
    }

    protected override void OnParametersSet()
    {
        TimelineTrackContext?.UpsertKeyframe?.Invoke(new TimelineKeyframeState
        {
            Id = id,
            TimeMs = TimeMs,
            Position = Position,
            Rotation = Rotation,
            Scale = Scale
        });
    }

    public void Dispose()
    {
        TimelineTrackContext?.RemoveKeyframe?.Invoke(id);
    }
}
