@code {
    [CascadingParameter]
    public MeshContext? MeshContext { get; set; }

    [Parameter]
    public string Color { get; set; } = "#ffffff";

    [Parameter]
    public double Opacity { get; set; } = 1;

    protected override void OnParametersSet()
    {
        MeshContext?.SetOutline?.Invoke(new OutlineState
        {
            Color = Color,
            Opacity = Opacity
        });
    }
}
