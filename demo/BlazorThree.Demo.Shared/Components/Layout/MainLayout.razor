@inherits LayoutComponentBase

<div class="demo-layout-shell">
    <aside class="demo-nav">
        <h1>BlazorThree</h1>

        <nav>
            <NavLink href="" Match="NavLinkMatch.All" class="demo-nav-link">Scene Playground</NavLink>
            <NavLink href="solar-system" class="demo-nav-link">Solar System</NavLink>
        </nav>
    </aside>

    <main class="demo-content">
        <header class="demo-topbar" role="region" aria-label="Project links">
            <div class="demo-topbar-text">Like this demo? Support the project.</div>
            <div class="demo-topbar-actions">
                <a class="demo-github-button"
                   href="https://github.com/nicolaparo/BlazorThree"
                   target="_blank"
                   rel="noopener noreferrer">
                    <svg class="demo-github-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                        <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8" />
                    </svg>
                    View on GitHub
                </a>
            </div>
        </header>

        <section class="demo-page-content">
            @Body
        </section>
    </main>
</div>

<style>
    .demo-layout-shell {
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr);
        width: 100%;
        height: 100vh;
        overflow: hidden;
        background: #04070f;
    }

    .demo-nav {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        padding: 1.4rem 1rem;
        border-right: 1px solid rgba(190, 205, 255, 0.18);
        background: rgba(10, 14, 24, 0.96);
        color: #d5defd;
    }

    .demo-nav h1 {
        margin: 0;
        font-size: 1.15rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .demo-nav p {
        margin: 0 0 0.8rem;
        font-size: 0.8rem;
        color: rgba(213, 222, 253, 0.72);
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .demo-nav nav {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
    }

    .demo-nav-link {
        display: block;
        padding: 0.7rem 0.8rem;
        border: 1px solid rgba(173, 189, 245, 0.25);
        border-radius: 0.65rem;
        color: #d5defd;
        text-decoration: none;
        background: rgba(18, 27, 45, 0.45);
        transition: background-color 150ms ease, border-color 150ms ease, color 150ms ease;
    }

    .demo-nav-link:hover {
        color: #ffffff;
        border-color: rgba(189, 205, 255, 0.72);
        background: rgba(44, 62, 103, 0.72);
    }

    .demo-nav-link.active {
        color: #0d1528;
        background: #9bc6ff;
        border-color: transparent;
        font-weight: 600;
    }

    .demo-content {
        min-width: 0;
        min-height: 0;
        height: 100%;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
    }

    .demo-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.9rem;
        padding: 0.55rem 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(31, 43, 71, 0.92);
        color: #e7eefc;
        z-index: 6;
    }

    .demo-topbar-text {
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.01em;
    }

    .demo-topbar-actions {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .demo-github-button {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.34rem 0.72rem;
        border: 1px solid #3d444d;
        border-radius: 0.45rem;
        background: #24292f;
        color: #f0f6fc;
        font-size: 0.86rem;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
        transition: background-color 120ms ease, border-color 120ms ease, transform 120ms ease;
    }

    .demo-github-button:hover {
        border-color: #8b949e;
        background: #2f363d;
        color: #ffffff;
    }

    .demo-github-button:active {
        transform: translateY(1px);
    }

    .demo-github-icon {
        width: 1rem;
        height: 1rem;
    }

    .demo-page-content {
        min-height: 0;
    }

    @@media (max-width: 900px) {
        .demo-layout-shell {
            grid-template-columns: 210px minmax(0, 1fr);
        }

        .demo-nav {
            padding: 1rem 0.75rem;
        }

        .demo-topbar {
            flex-direction: column;
            align-items: flex-start;
            padding: 0.65rem 0.75rem;
        }

        .demo-topbar-actions {
            width: 100%;
            justify-content: space-between;
        }
    }
</style>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
