@page "/"
@using BlazorThree.Engine

<PageTitle>BlazorThree Demo</PageTitle>

<div class="scene-page">
    <Scene Width="100%" Height="100%" ClearColor="#101925">
        <Camera Fov="65" Position="@(cinematicCamera ? new(0f, 2.2f, 9f) : new(0f, 1.4f, 7f))">
            <Transition Property="@nameof(Camera.Position)" DurationMs="900" Easing="@Easings.EaseInOutQuad" />
            <OrbitControls Enabled="true" EnableDamping="true" DampingFactor="0.09" />
        </Camera>
        <Light Type="LightDefinitions.Directional"
               Intensity="@(dramaticLight ? 2.2 : 1.3)"
               Position="@(dramaticLight ? new(7f, 10f, -2f) : new(6f, 8f, 3f))"
               Color="@(dramaticLight ? "#ffd2a1" : "#ffffff")">
            <Transition Properties="@(new[] { nameof(Light.Intensity), nameof(Light.Position), nameof(Light.Color) })" DurationMs="900" Easing="@Easings.EaseInOutQuad" />
        </Light>
        <Group Position="@(stageActive ? new(0f, 0.9f, 0f) : Vector3.Zero)"
               Rotation="@(stageActive ? new(0f, 1.8f, 0f) : Vector3.Zero)"
               Scale="@(stageActive ? new(-1f, -1f, -1f) : Vector3.One)">

            <Transition Properties="@([nameof(Group.Position), nameof(Group.Rotation), nameof(Group.Scale)])"
                        DurationMs="1200"
                        Easing="@Easings.EaseInOutQuad" />

            @if (boxVisible)
            {
                <Mesh Position="@(new(-1.7f, 0.1f, 0f))"
                      OnClick='() => selectedElement = "box"'>
                    <BoxGeometry Width="@(boxGeometryWide ? 1.8 : 1)" Height="@(boxGeometryTall ? 1.5 : 1)" Depth="1">
                        <Transition Properties="@(new[] { nameof(BoxGeometry.Width), nameof(BoxGeometry.Height) })"
                                    DurationMs="200"
                                    Easing="@Easings.EaseInOutQuad" />
                    </BoxGeometry>
                    <MeshStandardMaterial Color="@(boxMaterialWarm ? "#ff9d3f" : "#f5f500")" Metalness="0.05" Roughness="0.55">
                        <Transition Property="@nameof(MeshStandardMaterial.Color)" DurationMs="200" Easing="@Easings.EaseInOutQuad" />
                    </MeshStandardMaterial>
                    <Outline Color="@(selectedElement == "box" ? "#ff0000" : "#8fb0ff")" Opacity="@(boxOutlineOn ? 0.98 : 0.06)">
                        <Transition Properties="@(new[] { nameof(Outline.Opacity), nameof(Outline.Color) })" DurationMs="200" Easing="@Easings.EaseInOutQuad" />
                    </Outline>
                </Mesh>
            }

            @if (sphereVisible)
            {
                <Mesh id="sphere"
                      Position="@(new Vector3(1.7f, 0.1f, 0f))"
                      Scale="sphereScale"
                      OnMouseEnter="() => sphereScale = Vector3.One * 1.5f"
                      OnMouseLeave="() => sphereScale = Vector3.One"
                      OnClick='() => selectedElement = "sphere"'>

                    <Transition Property="@nameof(Mesh.Scale)" DurationMs="650" Easing="@Easings.EaseInOutQuad"></Transition>
                    <MeshStandardMaterial TextureUrl="_content/BlazorThree.Demo.Shared/textures/uv_grid_opengl.jpg"
                                          Color="@(sphereMaterialCool ? "#62b4ff" : "#ffbf69")"
                                          Metalness="0.05"
                                          Roughness="0.55">
                        <Transition Property="@nameof(MeshStandardMaterial.Color)" DurationMs="200" Easing="@Easings.EaseInOutQuad" />
                    </MeshStandardMaterial>
                    <SphereGeometry Radius="@(sphereGeometryLarge ? 1.2 : 0.9)" WidthSegments="48" HeightSegments="24">
                        <Transition Property="@nameof(SphereGeometry.Radius)" DurationMs="200" Easing="@Easings.EaseInOutQuad" />
                    </SphereGeometry>
                    <Outline Color="#0000ff" Opacity="@(selectedElement == "sphere" ? 1 : 0)">
                        <Transition Property="@nameof(Outline.Opacity)" DurationMs="200" Easing="@Easings.EaseInOutQuad" />
                    </Outline>
                </Mesh>
            }
        </Group>

        <Mesh Position="@(new Vector3(0f, -1.5f, 0f))">
            <BoxGeometry Width="6" Height="0.18" Depth="3" />
            <MeshStandardMaterial Color="#6ca0ff" Metalness="0.15" Roughness="0.9" />
        </Mesh>
    </Scene>

    <aside class="right-panel">
        <h2>Controls</h2>
        <button class="btn btn-primary" @onclick="() => stageActive = !stageActive">
            Toggle Stage (@(stageActive ? "active" : "idle"))
        </button>
        <button class="btn btn-secondary" @onclick="() => cinematicCamera = !cinematicCamera">
            Camera Move (@(cinematicCamera ? "far" : "near"))
        </button>
        <button class="btn btn-secondary" @onclick="() => dramaticLight = !dramaticLight">
            Light Transition (@(dramaticLight ? "dramatic" : "neutral"))
        </button>
        <div class="control-list">
            <div class="control-item">
                <input id="box-visible" type="checkbox" @bind="boxVisible" />
                <label for="box-visible">Show box</label>
            </div>
            <div class="control-item">
                <input id="sphere-visible" type="checkbox" @bind="sphereVisible" />
                <label for="sphere-visible">Show sphere</label>
            </div>
            <div class="control-item">
                <input id="box-geometry-wide" type="checkbox" @bind="boxGeometryWide" />
                <label for="box-geometry-wide">Box: use wide shape</label>
            </div>
            <div class="control-item">
                <input id="box-geometry-tall" type="checkbox" @bind="boxGeometryTall" />
                <label for="box-geometry-tall">Box: use tall shape</label>
            </div>
            <div class="control-item">
                <input id="box-material-warm" type="checkbox" @bind="boxMaterialWarm" />
                <label for="box-material-warm">Box: warm material color</label>
            </div>
            <div class="control-item">
                <input id="box-outline-on" type="checkbox" @bind="boxOutlineOn" />
                <label for="box-outline-on">Box: show outline</label>
            </div>
            <div class="control-item">
                <input id="sphere-geometry-large" type="checkbox" @bind="sphereGeometryLarge" />
                <label for="sphere-geometry-large">Sphere: larger size</label>
            </div>
            <div class="control-item">
                <input id="sphere-material-cool" type="checkbox" @bind="sphereMaterialCool" />
                <label for="sphere-material-cool">Sphere: cool material color</label>
            </div>
        </div>
    </aside>
</div>

<style>
    .scene-page {
        position: relative;
        width: 100%;
        height: 100%;
    }

    .right-panel {
        position: absolute;
        top: 0;
        right: 0;
        height: 100%;
        width: min(320px, 32vw);
        padding: 1rem;
        background: rgba(12, 16, 24, 0.76);
        backdrop-filter: blur(8px);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        color: #ffffff;
        z-index: 5;
    }

    .control-list {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
    }

    .control-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        line-height: 1.3;
    }

    .control-item label {
        cursor: pointer;
    }

        .right-panel h2 {
            margin: 0;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

    @@media (max-width: 720px) {
        .right-panel {
            width: 220px;
        }
    }
</style>

@code {
    private bool stageActive;
    private bool boxVisible = true;
    private bool sphereVisible = true;
    private string selectedElement = "";
    private Vector3 sphereScale = Vector3.One;
    private bool cinematicCamera;
    private bool dramaticLight;
    private bool boxGeometryWide;
    private bool boxGeometryTall;
    private bool boxMaterialWarm;
    private bool boxOutlineOn = true;
    private bool sphereGeometryLarge;
    private bool sphereMaterialCool;
}
